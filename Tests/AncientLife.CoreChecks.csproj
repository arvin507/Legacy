<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="../Scripts/Models/**/*.cs" Link="Scripts/Models/%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Include="../Scripts/Systems/**/*.cs" Link="Scripts/Systems/%(RecursiveDir)%(Filename)%(Extension)" />
    <Compile Include="../Scripts/Managers/GameSession.cs" Link="Scripts/Managers/GameSession.cs" />
    <Compile Include="../Scripts/Managers/EventManager.cs" Link="Scripts/Managers/EventManager.cs" />
    <Compile Include="../Scripts/Managers/EraManager.cs" Link="Scripts/Managers/EraManager.cs" />
  </ItemGroup>
</Project>
